{
    // XDebug listen config for WordPress container (port 9003)
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Listen for XDebug",
            "type": "php",
            "request": "launch",
            "pathMappings": {
                "/var/www/html": "${workspaceFolder}/wp"
            },
            "port": 9003
        }
    ]
}
